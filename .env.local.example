# Copiá este archivo como ".env.local" y completá los valores.
#
# ¿De dónde salen? En https://supabase.com entrá a tu proyecto y andá a:
#   Settings -> API
#   - "Project URL"      -> NEXT_PUBLIC_SUPABASE_URL
#   - "anon public" key  -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# La clave "anon" es pública por diseño: la seguridad real la dan las
# políticas de Row Level Security (RLS) definidas en supabase/setup.sql.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
